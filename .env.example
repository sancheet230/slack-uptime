# Slack (Required)
SLACK_BOT_TOKEN=xoxp-your-token-here
POLL_SECONDS=60

# Supabase (Required for persistence)
# Use Project URL from: Supabase Dashboard → Settings → API → Project URL
# Must be https://xxx.supabase.co - do NOT use the postgresql:// database connection string
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Optional: For dashboard auth in production
# DASHBOARD_SECRET_KEY=optional-secret-for-auth
